{
  plugins: {
    entries: {
      docwen: {
        enabled: true,
        config: {
          allowDownload: true,
          releaseRepo: "ZHYX91/docwen",
          releaseTag: "v0.0.0",
          checksumsAsset: "SHA256SUMS.txt",
          downloadTimeoutMs: 180000
        }
      }
    }
  }
}
